{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PKI Maturity Model schema",
  "description": "Schema for the machine-readable PKI Maturity Model definition (data/pkimm-model-<version>.yaml). See https://pkic.org/wg/pkimm/model/ for the human-readable model.",
  "version": "1.0.0",
  "type": "object",
  "required": ["schemaVersion", "version", "modules"],
  "properties": {
    "schemaVersion": {
      "description": "Version of the schema this file conforms to. Used by tools to load the matching schema for validation.",
      "type": "string",
      "const": "1.0.0"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "categories"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[GMOR]$"
          },
          "name": {
            "type": "string",
            "pattern": "^(Governance|Management|Operations|Resources)$"
          },
          "description": { "type": "string" },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "weight", "name", "description"],
              "properties": {
                "id": { "type": "string" },
                "weight": { "type": "integer" },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "levels": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["number", "name", "description"],
                    "properties": {
                      "number": { "type": "integer" },
                      "name": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                },
                "requirements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "weight", "description", "guidance", "assessment", "references"],
                    "properties": {
                      "id": { "type": "string" },
                      "weight": { "type": "integer" },
                      "description": { "type": "string" },
                      "guidance": { "type": "string" },
                      "assessment": { "type": "string" },
                      "references": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
